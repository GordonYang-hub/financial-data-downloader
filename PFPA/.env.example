# Copy to ".env" and fill in. Loaded automatically if python-dotenv is installed.

# Free FRED API key (required for interest-rate data):
#   https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_key_here

# Optional free Tiingo API key for official price data (https://www.tiingo.com).
# If unset, prices fall back to yfinance (no key required).
TIINGO_API_KEY=

# SEC's fair-access policy requires a descriptive User-Agent with a contact email.
SEC_USER_AGENT=PFPA research your_email@example.com

# Optional: where to cache the SEC ticker map (defaults to ~/.pfpa_cache)
# PFPA_CACHE=/path/to/cache
